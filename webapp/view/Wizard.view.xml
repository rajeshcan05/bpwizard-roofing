<mvc:View controllerName="project1.controller.Wizard"
    xmlns:mvc="sap.ui.core.mvc" 
    xmlns="sap.m" 
    xmlns:f="sap.f"
    xmlns:form="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:mc="sap.suite.ui.microchart" 
    height="100%">
    
    <f:DynamicPage class="pageGrayBackground">
        
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="Create Business Partner" level="H2"/>
                </f:heading>
                <f:expandedContent>
                    <ObjectStatus text="Using Template: {wizardData>/TemplateID}" state="Information" inverted="true" />
                </f:expandedContent>
                <f:navigationActions>
                    <Button icon="sap-icon://nav-back" press="onNavBack" tooltip="Back to Directory" type="Transparent"/>
                </f:navigationActions>
            </f:DynamicPageTitle>
        </f:title>

        <f:content>
            <VBox class="sapUiResponsiveMargin">
                <VBox class="wizardRedBoxFrame">
                    
                    <HBox class="sapUiMediumMarginBegin sapUiSmallMarginTop" alignItems="Center">
                        <mc:RadialMicroChart size="M" percentage="{wizardData>/progress}" valueColor="Good" />
                        <Title text="Completion Status: {wizardData>/progress}%" class="sapUiSmallMarginBegin" level="H3"/>
                    </HBox>

                    <Wizard id="bpWizard" 
                            complete="onWizardCompleted" 
                            stepActivate="onStepActivate" 
                            renderMode="Page"
                            showNextButton="false"
                            class="sapUiResponsivePadding--header sapUiResponsivePadding--content">
                        
                        <WizardStep id="step1" title="Basic Info" icon="sap-icon://customer" validated="true">
                            <form:SimpleForm editable="true" layout="ColumnLayout" columnsM="2" columnsL="2">
                                <Label text="BP ID (Auto)" /><Input value="[System Generated]" editable="false"/>
                                <Label text="Category" /><Input value="{wizardData>/BusinessPartnerCategory}" />
                                <Label text="Full Name" /><Input value="{wizardData>/BusinessPartnerFullName}" />
                                <Label text="First Name" /><Input value="{wizardData>/FirstName}" />
                                <Label text="Grouping" /><Input value="{wizardData>/BusinessPartnerGrouping}" />
                                <Label text="Created By" /><Input value="{wizardData>/CreatedByUser}" editable="false"/>
                            </form:SimpleForm>
                            <HBox justifyContent="End" class="sapUiMediumMarginTop">
                                <Button text="Step 2" type="Emphasized" press="onNextStep" />
                            </HBox>
                        </WizardStep>

                        <WizardStep id="step2" title="Address Details" icon="sap-icon://map-2" validated="true">
                            <form:SimpleForm editable="true" layout="ColumnLayout" columnsM="2" columnsL="2">
                                <Label text="Country" /><Input value="{wizardData>/Address/Country}" />
                                <Label text="City Name" /><Input value="{wizardData>/Address/CityName}" />
                                <Label text="Postal Code" /><Input value="{wizardData>/Address/CompanyPostalCode}" />
                                <Label text="City Code" /><Input value="{wizardData>/Address/CityCode}" />
                                <Label text="Time Zone" /><Input value="{wizardData>/Address/AddressTimeZone}" />
                            </form:SimpleForm>
                            <HBox justifyContent="SpaceBetween" class="sapUiMediumMarginTop">
                                <Button text="Previous" type="Transparent" press="onPrevStep" />
                                <Button text="Step 3" type="Emphasized" press="onNextStep" />
                            </HBox>
                        </WizardStep>

                        <WizardStep id="step3" title="Assigned Roles" icon="sap-icon://role" validated="true">
                            <Table items="{wizardData>/Roles}">
                                <columns>
                                    <Column><Text text="Business Partner"/></Column>
                                    <Column><Text text="Role Code"/></Column>
                                </columns>
                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Text text="{wizardData>BusinessPartner}" />
                                            <Input value="{wizardData>BusinessPartnerRole}" />
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                            <HBox justifyContent="SpaceBetween" class="sapUiMediumMarginTop">
                                <Button text="Previous" type="Transparent" press="onPrevStep" />
                                <Button text="Step 4" type="Emphasized" press="onNextStep" />
                            </HBox>
                        </WizardStep>

                        <WizardStep id="step4" title="Customer Info" icon="sap-icon://customer-briefing" validated="true">
                            <form:SimpleForm editable="true" layout="ColumnLayout" columnsM="2" columnsL="2">
                                <Label text="Customer ID" /><Input value="{wizardData>/Customer/Customer}" />
                                <Label text="Account Group" /><Input value="{wizardData>/Customer/CustomerAccountGroup}" />
                                <Label text="Customer Full Name" /><Input value="{wizardData>/Customer/CustomerFullName}" />
                                <Label text="BP Cust Name" /><Input value="{wizardData>/Customer/BPCustomerFullName}" />
                                <Label text="Created By" /><Input value="{wizardData>/Customer/CreatedByUser}" />
                            </form:SimpleForm>
                            <HBox justifyContent="SpaceBetween" class="sapUiMediumMarginTop">
                                <Button text="Previous" type="Transparent" press="onPrevStep" />
                                <Button text="Step 5" type="Emphasized" press="onNextStep" />
                            </HBox>
                        </WizardStep>

                        <WizardStep id="step5" title="Company Details" icon="sap-icon://factory" validated="true">
                            <Table items="{wizardData>/Company}">
                                <columns>
                                    <Column><Text text="Company Code"/></Column>
                                    <Column><Text text="Account By Customer"/></Column>
                                    <Column><Text text="Accounting Clerk"/></Column>
                                    <Column><Text text="Reconciliation Acct"/></Column>
                                </columns>
                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Input value="{wizardData>CompanyCode}" />
                                            <Input value="{wizardData>AccountByCustomer}" />
                                            <Input value="{wizardData>AccountingClerk}" />
                                            <Input value="{wizardData>ReconciliationAccount}" />
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                            <HBox justifyContent="SpaceBetween" class="sapUiMediumMarginTop">
                                <Button text="Previous" type="Transparent" press="onPrevStep" />
                                <Button text="Step 6" type="Emphasized" press="onNextStep" />
                            </HBox>
                        </WizardStep>

                        <WizardStep id="step6" title="Sales Area" icon="sap-icon://sales-order" validated="true">
                            <Table items="{wizardData>/SalesArea}">
                                <columns>
                                    <Column><Text text="Sales Org"/></Column>
                                    <Column><Text text="Dist. Channel"/></Column>
                                    <Column><Text text="Currency"/></Column>
                                    <Column><Text text="Payment Terms"/></Column>
                                    <Column><Text text="Incoterms"/></Column>
                                    <Column><Text text="Plant"/></Column>
                                </columns>
                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Input value="{wizardData>SalesOrganization}" />
                                            <Input value="{wizardData>DistributionChannel}" />
                                            <Input value="{wizardData>Currency}" />
                                            <Input value="{wizardData>CustomerPaymentTerms}" />
                                            <Input value="{wizardData>IncotermsClassification}" />
                                            <Input value="{wizardData>SupplyingPlant}" />
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                            <HBox justifyContent="SpaceBetween" class="sapUiMediumMarginTop">
                                <Button text="Previous" type="Transparent" press="onPrevStep" />
                                <Button text="Review &amp; Submit For Approval" type="Emphasized" press="onWizardCompleted" />
                            </HBox>
                        </WizardStep>

                    </Wizard>
                </VBox>
            </VBox>
        </f:content>
    </f:DynamicPage>
</mvc:View>