<mvc:View controllerName="bpwizard-roofing.controller.View1"
    xmlns:mvc="sap.ui.core.mvc" 
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <f:DynamicPage id="dynamicPageId" headerExpanded="true" toggleHeaderOnTitleClick="true" class="sapUiSizeCompact">
        
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="Business Partner Directory" level="H2"/>
                </f:heading>
                <f:expandedContent>
                    <Text text="Search and select a partner to initiate the data template wizard." class="sapUiSmallMarginBottom"/>
                </f:expandedContent>
                
                <f:actions>
                    <Button text="Create Template" type="Accept" press="onCreateTemplate" />
                </f:actions>

            </f:DynamicPageTitle>
        </f:title>

        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <fb:FilterBar id="filterBar" search="onSearch" showClearOnFB="true" clear="onClear" useToolbar="false">
                    <fb:filterGroupItems>
                        <fb:FilterGroupItem groupName="G1" name="ID" label="Company Code" visibleInFilterBar="true">
                            <fb:control><Input id="filterID" placeholder="e.g. 100458..." /></fb:control>
                        </fb:FilterGroupItem>
                        <fb:FilterGroupItem groupName="G1" name="Category" label="Category" visibleInFilterBar="true">
                            <fb:control><Input id="filterCategory" placeholder="Enter Category..." /></fb:control>
                        </fb:FilterGroupItem>
                        <fb:FilterGroupItem groupName="G1" name="Name" label="Sales Area" visibleInFilterBar="true">
                            <fb:control><Input id="filterName" placeholder="Enter Name..." /></fb:control>
                        </fb:FilterGroupItem>
                        <fb:FilterGroupItem groupName="G1" name="Role" label="BP Role" visibleInFilterBar="true">
                            <fb:control><Input id="filterRole" placeholder="e.g. FLCU00..." /></fb:control>
                        </fb:FilterGroupItem>
                    </fb:filterGroupItems>
                </fb:FilterBar>
            </f:DynamicPageHeader>
        </f:header>

        <f:content>
            <Table id="bpTable"
                   items="{
                        path: '/A_BusinessPartner',
                        parameters: { expand: 'to_BusinessPartnerRole' }
                   }"
                   mode="SingleSelectMaster"
                   selectionChange="onSelectionChange"
                   growing="true"
                   growingThreshold="100"
                   class="myFloatingTable sapUiResponsiveMargin"> 

                <headerToolbar>
                    <OverflowToolbar style="Clear">
                        <Title id="tableTitle" text="Available Partners" level="H3" class="sapUiSmallMarginBegin"/>
                        <ToolbarSpacer />
                        <Button icon="sap-icon://sort" type="Transparent" tooltip="Sort Data" />
                        <Button icon="sap-icon://excel-attachment" type="Transparent" tooltip="Export to Excel" />
                        <Button icon="sap-icon://action-settings" type="Transparent" tooltip="Table Settings" />
                    </OverflowToolbar>
                </headerToolbar>

                <noData>
                    <IllustratedMessage 
                        illustrationType="sapIllus-EmptyList" 
                        title="No Partners Found" 
                        description="Try adjusting your search filters above."/>
                </noData>

                <columns>
                    <Column width="30%"><Text text="Business Partner Details" /></Column>
                    <Column width="15%" hAlign="Center"><Text text="Category" /></Column>
                    <Column width="10%"><Text text="Grouping" /></Column>
                    <Column width="15%"><Text text="Created By" /></Column>
                    <Column width="30%"><Text text="Assigned Roles" /></Column>
                </columns>

                <items>
                    <ColumnListItem type="Navigation" press="onSelectionChange">
                        <cells>
                            <ObjectIdentifier title="{BusinessPartnerFullName}" text="ID: {BusinessPartner}" />

                            <ObjectStatus 
                                text="{ path: 'BusinessPartnerCategory', formatter: '.formatCategoryText' }" 
                                icon="{ path: 'BusinessPartnerCategory', formatter: '.formatCategoryIcon' }"
                                state="Success" 
                                inverted="true" />

                            <Text text="{BusinessPartnerGrouping}" />
                            
                            <HBox alignItems="Center">
                                <Avatar src="sap-icon://person-placeholder" displaySize="XS" class="sapUiTinyMarginEnd" />
                                <Text text="{CreatedByUser}" />
                            </HBox>

                            <HBox items="{path: 'to_BusinessPartnerRole', templateShareable: false}" wrap="Wrap">
                                <ObjectStatus 
                                    text="{BusinessPartnerRole}" 
                                    state="{ path: 'BusinessPartnerRole', formatter: '.formatRoleColor' }" 
                                    inverted="true" 
                                    class="sapUiTinyMarginEnd sapUiTinyMarginBottom" />
                            </HBox>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </f:content>
    </f:DynamicPage>
</mvc:View>